---
import { industries } from '../data/site';
---
<section class="section" id="industries">
  <div class="container">
    <div class="section-head animate-on-scroll">
      <span class="eyebrow">Industries</span>
      <h2>Complex operations, clearer systems.</h2>
      <p class="lead">I specialize where processes are complex, workforces are distributed, and adoption has lagged.</p>
    </div>
    <div class="grid three animate-on-scroll stagger-children">
      {industries.map(([title, description, slug], index) => (
        <a class={`industry card lift tint-${index + 1}`} href={`/portfolio?industry=${slug}`}>
          <span class="icon-tile">{String(index + 1).padStart(2, '0')}</span>
          <h3>{title}</h3>
          <p>{description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .industry h3 {
    margin: 18px 0 10px;
  }

  .industry p {
    color: var(--muted);
  }

  .tint-2 { background: #f7fee7; }
  .tint-3 { background: #fff7ed; }
  .tint-4 { background: #f0fdf4; }
  .tint-5 { background: #f8fafc; }
  .tint-6 { background: #fdf2f8; }
</style>
