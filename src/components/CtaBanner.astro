---
interface Props {
  heading?: string;
  cta?: string;
  href?: string;
}

const { heading = "Have a process that's slowing your team down?", cta = "Let's Fix It Together", href = '/#contact' } = Astro.props;
---
<section class="cta-band">
  <div class="container cta-inner">
    <h2>{heading}</h2>
    <a class="button light" href={href}>{cta}</a>
  </div>
</section>

<style>
  .cta-band {
    background: var(--blue);
    color: #fff;
    padding: 46px 0;
  }

  .cta-inner {
    display: flex;
    gap: 24px;
    align-items: center;
    justify-content: space-between;
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
  }

  @media (max-width: 720px) {
    .cta-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
