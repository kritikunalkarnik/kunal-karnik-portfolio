---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href="/">Kunal Karnik</a>
      <p>Building meaningful technology. Creating lasting impact.</p>
    </div>
    <nav aria-label="Footer">
      <a href="/#process">Process</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
      <a href="/careers">Careers</a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <span>© {year} Kunal Karnik. All rights reserved.</span>
    <span>Privacy · Terms</span>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    color: #cbd5e1;
    padding: 56px 0 26px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: start;
  }

  .footer-brand {
    display: inline-block;
    margin-bottom: 8px;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 900;
  }

  .footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: #e2e8f0;
    font-weight: 750;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 42px;
    padding-top: 22px;
    border-top: 1px solid rgba(226, 232, 240, 0.16);
    color: #94a3b8;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .footer-grid,
    .footer-bottom {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
  }
</style>
